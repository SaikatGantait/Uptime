# ============================================================
# DPin Uptime Monitor — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# All apps (api, hub, validator, frontend) read from this file.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# SQLite (default for local development — no extra setup needed)
DATABASE_URL="file:./dev.db"
# For PostgreSQL, use:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/uptime"

# ── API Server ───────────────────────────────────────────────
PORT="5050"

# ── Authentication ───────────────────────────────────────────
# Set to "true" to skip JWT verification (uses DEMO_USER_ID instead)
DISABLE_AUTH="true"
DEMO_USER_ID="demo-user"

# Clerk (optional — only needed when DISABLE_AUTH="false")
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nREPLACE_WITH_RSA_PUBLIC_KEY\n-----END PUBLIC KEY-----"

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:5050"

# ── Solana Keypairs ──────────────────────────────────────────
# JSON array of bytes. Used for validator identity and payout signing.
# These test keys work for local dev — replace with real keypairs in production.
PRIVATE_KEY="[92,154,201,76,45,235,88,221,62,194,36,122,115,151,233,42,18,84,176,131,75,173,129,156,74,247,185,192,234,143,12,195]"
PAYER_PRIVATE_KEY="[92,154,201,76,45,235,88,221,62,194,36,122,115,151,233,42,18,84,176,131,75,173,129,156,74,247,185,192,234,143,12,195]"

# ── Alerts: Email (Resend) ───────────────────────────────────
# Sign up at https://resend.com — leave blank to disable email alerts
RESEND_API_KEY=""
ALERT_EMAIL_FROM="alerts@your-domain.com"

# ── Alerts: SMS (Twilio) ─────────────────────────────────────
# Sign up at https://twilio.com — leave blank to disable SMS alerts
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER="+10000000000"

# ── Alert Engine Tuning ──────────────────────────────────────
ALERT_RETRY_MAX_ATTEMPTS="5"
ALERT_RETRY_BASE_DELAY_SEC="30"
ALERT_REMINDER_MINUTES="10"
MONITOR_TICK_MS="15000"
FAST_RECHECK_SECONDS="30"
NORMAL_RECHECK_SECONDS="60"
STABLE_RECHECK_SECONDS="180"

# ── API Rate Limiting ────────────────────────────────────────
REQUEST_BODY_LIMIT="256kb"
API_RATE_LIMIT_WINDOW_MS="60000"
API_RATE_LIMIT_MAX_REQUESTS="300"
